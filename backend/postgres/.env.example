# Postgres DB Config
POSTGRES_USER=melodygenerator_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=melodygenerator_db

# Connection settings (used by the API to connect)
PG_DB_HOST=postgres
PG_DB_PORT=5432
PG_DB_MIN_CONNECTIONS=10
PG_DB_MAX_CONNECTIONS=100
PG_DB_COMMAND_TIMEOUT=60
PG_DB_MAX_INACTIVE_CONNECTION_LIFETIME=300
