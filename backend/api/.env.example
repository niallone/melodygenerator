# API settings
API_URL=https://api.melodygenerator.fun
APP_URL=https://melodygenerator.fun

# File paths
OUTPUT_DIR=/usr/src/api/app/output
MODEL_DIR=/usr/src/api/app/model
SOUNDFONT_PATH=/usr/share/sounds/sf2/FluidR3_GM.sf2

# Database (must match backend/postgres/.env)
POSTGRES_USER=melodygenerator_user
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=melodygenerator_db
PG_DB_HOST=postgres
PG_DB_PORT=5432

# CORS
ALLOWED_ORIGINS=https://melodygenerator.fun

# Debug and logging
DEBUG=false
LOGGING_LEVEL=INFO
