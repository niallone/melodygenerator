# API settings
API_URL=https://api.melodygenerator.fun
APP_URL=https://melodygenerator.fun

# Secret key for JWT (must be at least 20 characters in production)
SECRET_KEY=your-secret-key-at-least-20-chars

# File paths
OUTPUT_DIR=/usr/src/api/app/output
MODEL_DIR=/usr/src/api/app/model
SOUNDFONT_PATH=/usr/share/sounds/sf2/FluidR3_GM.sf2

# CORS
ALLOWED_ORIGINS=https://melodygenerator.fun

# Debug and logging
DEBUG=false
LOGGING_LEVEL=INFO
